generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ActivityLevel {
  sedentary
  moderate
  active
  athlete
}

enum DietType {
  omnivore
  vegetarian
  vegan
  keto
  paleo
}

enum SubscriptionStatus {
  free
  premium
  cancelled
}

enum GlycemicImpact {
  low
  medium
  high
}

enum RecommendationType {
  food_swap
  daily_challenge
  supplement
  meal_suggestion
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  name               String?
  age                Int?
  sex                String?
  weight             Float?
  height             Float?
  activityLevel      ActivityLevel?
  goals              String[]
  dietType           DietType?
  allergies          String[]
  dislikedFoods      String?
  subscriptionStatus SubscriptionStatus @default(free)
  stripeCustomerId   String?
  onboardingComplete Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  biomarkerProfile BiomarkerProfile?
  meals            Meal[]
  dailyScores      DailyScore[]
  mealPlans        MealPlan[]
  recommendations  Recommendation[]
  streak           Streak?
}

model BiomarkerProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  hba1c            Float?
  fastingGlucose   Float?
  totalCholesterol Float?
  hdl              Float?
  ldl              Float?
  triglycerides    Float?
  vitaminD         Float?
  ferritin         Float?
  b12              Float?
  tsh              Float?
  dnaVariants      String?
  microbiomeScore  Float?
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Meal {
  id                 String         @id @default(cuid())
  userId             String
  imageUrl           String?
  foodsDetected      Json
  macros             Json
  fiberDiversityScore Float
  glycemicImpact     GlycemicImpact
  processedFoodRatio Float
  score              Int
  feedback           String
  loggedAt           DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loggedAt])
}

model DailyScore {
  id             String   @id @default(cuid())
  userId         String
  date           DateTime @db.Date
  score          Int
  fiberDiversity Float
  sugarLoad      Float
  wholeFoodRatio Float
  mealsLogged    Int
  caloriesTotal  Int
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model MealPlan {
  id            String   @id @default(cuid())
  userId        String
  weekStartDate DateTime @db.Date
  meals         Json
  groceryList   Json
  generatedAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, weekStartDate])
}

model Recommendation {
  id        String             @id @default(cuid())
  userId    String
  type      RecommendationType
  content   String
  priority  Int                @default(0)
  dismissed Boolean            @default(false)
  createdAt DateTime           @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dismissed])
}

model Streak {
  id            String   @id @default(cuid())
  userId        String   @unique
  currentStreak Int      @default(0)
  longestStreak Int      @default(0)
  lastLogDate   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
